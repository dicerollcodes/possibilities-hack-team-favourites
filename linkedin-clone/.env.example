# Copy to .env.local (gitignored) and fill in to enable live AI grading.
# Two supported schemes (use either) — keys are tried in order, with a
# cached-score fallback if none are set or all fail.

# Scheme A: one comma-separated list
VITE_NVIDIA_KEYS=

# Scheme B: numbered keys
VITE_NVIDIA_KEY_1=your_nvidia_api_key_here
VITE_NVIDIA_KEY_2=your_nvidia_api_key_fallback_here
